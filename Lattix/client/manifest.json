{
  "manifest_version": 3,
  "name": "Lattix — quantum-resistant messaging",
  "version": "1.1.0",
  "description": "End-to-end, post-quantum encrypted chat and file sharing. Connects to your own Lattix relay server.",
  "action": {
    "default_title": "Open Lattix"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["notifications", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
